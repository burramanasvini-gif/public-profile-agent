# Required: used to synthesize scraped public data into a structured, well-written profile.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: model to use for synthesis (defaults to claude-sonnet-4-6 if unset)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: number of DuckDuckGo web results to scrape per query (default 8)
MAX_SEARCH_RESULTS=8
